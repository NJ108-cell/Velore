{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "notifications_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Push notifications enabled"
    },
    "email_updates_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Email updates enabled"
    },
    "dark_mode": {
      "type": "boolean",
      "default": false,
      "description": "Dark mode preference"
    },
    "voice_guidance": {
      "type": "boolean",
      "default": true,
      "description": "Voice guidance during lessons"
    },
    "auto_play_videos": {
      "type": "boolean",
      "default": false,
      "description": "Auto-play video content"
    },
    "anonymous_data_collection": {
      "type": "boolean",
      "default": true,
      "description": "Share anonymous usage data"
    },
    "language": {
      "type": "string",
      "default": "en",
      "enum": [
        "en",
        "es",
        "fr",
        "de",
        "zh",
        "ar"
      ],
      "description": "Preferred language"
    }
  },
  "required": []
}